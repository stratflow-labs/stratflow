# ==============================================================================
# Application
# ==============================================================================

APP_NAME=stratflow
APP_ENV=dev


# ==============================================================================
# Database
# ==============================================================================

DB_USER=postgres
DB_PASS=change-me-postgres-password
DB_NAME=stratflow
DB_PORT_HOST=5432
DB_URL=postgresql://postgres:change-me-postgres-password@127.0.0.1:5432/stratflow


# ==============================================================================
# API Gateway
# ==============================================================================

# Host port for nginx API gateway.
API_GATEWAY_PORT_HOST=8085


# ==============================================================================
# Frontend
# ==============================================================================

WEB_PORT_HOST=3000

# Public API URL used by the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8085/api
NEXT_PUBLIC_IDENTITY_CONNECT_URL=http://localhost:8085/connect/identity
NEXT_PUBLIC_STRATEGY_REGISTRY_CONNECT_URL=http://localhost:8085/connect/strategy-registry


# ==============================================================================
# Logging
# ==============================================================================

# true | false
LOG_COLOR=true

# console | json
LOG_FORMAT=console

# debug | info | error | off
LOG_LEVEL=debug


# ==============================================================================
# Identity Service
# ==============================================================================

# Internal service URLs used by other Docker services.
IDENTITY_URL=http://identity:8888/api
IDENTITY_GRPC_URL=identity:9090

# Development-only secrets. Replace in real environments.
TOKEN_HASH_SECRET=change-me-token-hash-secret
MASTER_SESSION_TOKEN=change-me-master-session-token


# ==============================================================================
# Strategy Registry Service
# ==============================================================================
